# Cashu mint URL. Leave commented out to use the Vite proxy (/mint → localhost:3338).
# Set explicitly only if the mint runs on a different host or port.
# VITE_MINT_URL=http://localhost:3338

# Signaling server URL. Leave commented out to use the Vite proxy (/ws → localhost:8080).
# Set explicitly only if the signaling server runs on a different host.
# VITE_SIGNALING_URL=ws://localhost:8080

# LND customer macaroon (hex-encoded) — needed for regtest invoice payment in tests
# VITE_LND_CUSTOMER_MACAROON_HEX=

# --- LAN Testing ---
# For testing from other devices on your network:
# 1. Start Vite with: npm run dev -- --host
# 2. Leave VITE_MINT_URL and VITE_SIGNALING_URL commented out (proxies handle it)
# 3. Access https://<your-lan-ip>:5173 from other devices
# 4. Accept the self-signed certificate warning
