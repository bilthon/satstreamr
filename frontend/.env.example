VITE_SIGNALING_URL=ws://localhost:8080
VITE_MINT_URL=http://localhost:3338

# Regtest-only: LND customer node REST API for auto-paying mint invoices in dev.
# The Vite dev server proxies /lnd-customer/* → VITE_LND_CUSTOMER_REST_URL
# with TLS verification disabled (self-signed cert in regtest).
VITE_LND_CUSTOMER_REST_URL=https://localhost:8082
# Hex-encoded admin macaroon for the lnd_customer node.
# Generate with: xxd -p -c 256 infra/lnd-data/lnd_customer/data/chain/bitcoin/regtest/admin.macaroon
VITE_LND_CUSTOMER_MACAROON_HEX=
