# LND connection details for the Nutshell Cashu mint
# Copy this file to .env.lnd and fill in real values after running:
#   docker compose up -d   (from infra/)
#   bash bootstrap-regtest.sh
#
# .env.lnd is gitignored. This example file is committed.

MINT_LND_REST_ENDPOINT=https://127.0.0.1:8081
MINT_LND_TLS_CERT_PATH=/path/to/satstreamr/infra/lnd-mint-creds/tls.cert
MINT_LND_MACAROON_PATH=/path/to/satstreamr/infra/lnd-mint-creds/admin.macaroon
