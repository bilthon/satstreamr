MINT_BACKEND_BOLT11_SAT=FakeWallet
MINT_URL=http://127.0.0.1:3338
MINT_PORT=3338
MINT_HOST=0.0.0.0
MINT_PRIVATE_KEY=<generate with: openssl rand -hex 32>
CASHU_DIR=/home/bilthon/Development/satstreamr/infra/cashu-data

# ─── SWITCH TO LND REST WALLET (once Unit 01 / Polar is ready) ─────────────────
# 1. Set the backend:
#    MINT_BACKEND_BOLT11_SAT=LndRestWallet
#
# 2. Add LND connection vars (copy from infra/.env.polar once generated by Unit 01):
#    LND_REST_ENDPOINT=https://127.0.0.1:8081
#    LND_CERT=/path/to/.polar/networks/<id>/volumes/lnd/mint-node/tls.cert
#    LND_MACAROON=<hex string — extract with: xxd -p -c 1000 <path>/admin.macaroon>
#
# 3. Remove or comment out MINT_BACKEND_BOLT11_SAT=FakeWallet above.
#
# 4. Restart the mint:
#    bash infra/start-mint.sh
# ────────────────────────────────────────────────────────────────────────────────
